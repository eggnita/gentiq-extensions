# IntrospectFN CLI Configuration
# Copy to ~/.ifn/config or export as environment variables.
# In GentiqOS, these are set as skill credentials in the admin dashboard.
#
# NOTE: When deployed as a Gent skill, IFN_API_KEY and IFN_BASE_URL are
# injected automatically. You do NOT need to configure anything manually.

# API base URL (required — no default, set via skill credentials or environment)
# Example: https://your-instance.example.com
# For local dev: http://localhost:8000
IFN_BASE_URL=

# Web app URL for deep links (optional)
# Defaults to IFN_BASE_URL if not set.
# IFN_WEB_URL=

# API key (required — set automatically by the skill credential system)
# Issued by an owner or developer in the IntrospectFN web UI.
# Scoped to assistant role (read + propose).
IFN_API_KEY=

# Skip SSL certificate validation
# Default: true (some deployments use self-signed certificates)
IFN_INSECURE=true
