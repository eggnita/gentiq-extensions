# IntrospectFN CLI Configuration
# Copy to ~/.ifn/config or export as environment variables.
# In GentiqOS, these are set as skill credentials in the admin dashboard.

# API base URL (required)
# Local dev:    http://localhost:8000
# Staging:      https://ifn-stage.mayuda.com
IFN_BASE_URL=http://localhost:8000

# API key (required)
# Issued by an owner or developer in the IntrospectFN web UI.
# Scoped to assistant role (read + propose).
IFN_API_KEY=
