# BigQuery Data Lake Skill — Environment Configuration
# Copy to ~/.config/gent-bq/config or set as environment variables

# Service Account JSON key (paste the full JSON string)
# Usually set via GentiqOS credential system, not manually
# BQ_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# GCP Project ID (required — extracted from SA JSON if not set)
BQ_PROJECT_ID=

# Default dataset for unqualified table references (optional)
BQ_DEFAULT_DATASET=

# BigQuery data location (default: EU)
BQ_LOCATION=EU

# Maximum bytes billed per query — cost safety guard (default: 1 GB)
# Set to 0 to disable the limit (not recommended)
BQ_MAX_BYTES_BILLED=1073741824

# Metadata cache TTL in seconds (default: 3600 = 1 hour)
# Datasets, tables, and locations are cached to avoid repeated API calls
BQ_CACHE_TTL=3600
